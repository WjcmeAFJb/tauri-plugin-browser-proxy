{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "browser-proxy-example",
  "version": "0.1.0",
  "identifier": "dev.tauri.browserproxy.example",
  "build": {
    "beforeDevCommand": "pnpm --filter browser-proxy-example dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "pnpm --filter browser-proxy-example build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "browser-proxy-example",
        "label": "main",
        "width": 640,
        "height": 360,
        "resizable": true,
        "minimizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "DeveloperTool"
  }
}
