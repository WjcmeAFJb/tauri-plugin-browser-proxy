{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Dev-time permissions for the browser-proxy-example. Wide open for demo — DO NOT copy blindly into your own app.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "browser-proxy:default",
    "fs:default",
    "fs:read-all",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "/**" }]
    },
    "notification:default",
    "dialog:default"
  ]
}
